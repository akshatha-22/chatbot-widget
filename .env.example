# Environment Configuration Example
# Copy this file to .env.local and fill in your actual values

# ================================
# FRONTEND (Client) Configuration
# ================================

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000/ws

# Environment
VITE_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_SENTRY=false

# ================================
# BACKEND Configuration
# ================================

# Server Configuration
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/chatbot_widget
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_TTL=3600

# JWT Configuration
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Security
# Comma-separated; include both localhost and 127.0.0.1 (browser treats them as different origins)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
ALLOWED_HOSTS=localhost,127.0.0.1

# Google Gemini (backend reads from repo-root .env.local — see backend/app/config.py)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# OpenAI / LLM Configuration (if using)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2048
OPENAI_TEMPERATURE=0.7

# File Upload Configuration
MAX_UPLOAD_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,txt,csv,json
UPLOAD_DIRECTORY=./uploads

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Email Configuration (if needed)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@chatbotwidget.com

# AWS S3 (if using for file storage)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_S3_BUCKET_NAME=chatbot-widget-uploads
AWS_S3_REGION=us-east-1

# Monitoring & Observability
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
DATADOG_API_KEY=your-datadog-api-key

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# CORS & Security Headers
ENABLE_CORS=true
ENABLE_SECURITY_HEADERS=true

# Session Configuration
SESSION_TIMEOUT_MINUTES=30
REMEMBER_ME_DAYS=7

# Distributed Cache (if using Redis)
CACHE_BACKEND=redis
CACHE_TTL_SECONDS=3600
